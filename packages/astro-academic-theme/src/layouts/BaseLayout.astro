---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import SocialLinks from '../components/SocialLinks.astro';
import Footer from '../components/Footer.astro';
import type { SiteConfig } from '../types.js';

interface Props {
  config: SiteConfig;
  title?: string;
  description?: string;
  showUserInfo?: boolean;
  currentPath?: string;
}

const {
  config,
  title,
  description,
  showUserInfo = true,
  currentPath = '/',
} = Astro.props;

const pageTitle = title ? `${title} | ${config.title}` : config.title;
const pageDescription = description || config.description;

// Compute active nav item for title rendering
const navItems = [
  { label: 'About', href: '/', exact: true },
  { label: 'Experience', href: '/experience/', exact: false },
  { label: 'Research', href: `/${config.pages.research}/`, exact: false },
  { label: 'Posts', href: `/${config.pages.posts}/`, exact: false },
];

function isNavActive(href: string, exact: boolean): boolean {
  if (exact) return currentPath === href || currentPath === href.replace(/\/$/, '');
  return currentPath.startsWith(href) || currentPath.startsWith(href.replace(/\/$/, ''));
}

const activeNavItem = navItems.find(item => isNavActive(item.href, item.exact));
const mainPaths = navItems.flatMap(n => [n.href, n.href.replace(/\/$/, '')]);
const isMainTabPage = mainPaths.includes(currentPath);
---

<!doctype html>
<html lang={config.defaultLanguage || 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <meta name="author" content={config.author} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{pageTitle}</title>
    <ClientRouter />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/academicons/1.9.4/css/academicons.min.css"
      integrity="sha512-IW0nhlW5MgNydsXJO40En2EoCkTTjZhI3yuODrZIc8cQ4h1XcF53PsqDHa09NqnkXuIe0Oiyyj171BqZFwISBw=="
      crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
      integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
      crossorigin="anonymous" />

    <script is:inline>
      (function(){
        var s=localStorage.getItem('theme'),d=window.matchMedia('(prefers-color-scheme:dark)').matches;
        if(s==='dark'||(!s&&d))document.documentElement.classList.add('dark');
        if(!window._themeSwap){
          document.addEventListener('astro:before-swap',function(e){
            e.newDocument.documentElement.classList.toggle('dark',
              document.documentElement.classList.contains('dark'));
          });
          window._themeSwap=true;
        }
      })();
    </script>
  </head>

  <body>
    <!-- Outer padding + centering (matches .outerPadding + .container) -->
    <div class="outer-padding">
      <div class="container">
        <!-- Header + content form one seamless card shape -->
        <Header config={config} currentPath={currentPath} hideTabs={isMainTabPage} />
        <div class="main-wrapper">
          <!-- Compact mobile profile bar (visible only on mobile) -->
          {showUserInfo && (
            <div class="mobile-profile">
              <img src={`/${config.avatar}`} alt={config.author} class="mobile-avatar" />
              <div class="mobile-profile-info">
                <div class="mobile-profile-text">
                  <span class="mobile-name">{config.author}</span>
                  {config.professions[0] && <span class="mobile-role">{config.professions[0]}</span>}
                </div>
                <div class="mobile-social">
                  <SocialLinks links={config.social} />
                </div>
              </div>
            </div>
          )}
          <div class="layout-grid">
            <!-- Sidebar column: md=8/24, lg=7/24 -->
            <div class="sidebar-col">
              <div class="sidebar-affix">
                <Sidebar config={config} showUserInfo={showUserInfo}>
                  <slot name="sidebar" />
                </Sidebar>
              </div>
            </div>
            <!-- Content column: md=16/24, lg=17/24 -->
            <div class="content-col">
              {isMainTabPage && activeNavItem && (
                <div class="page-nav-row">
                  <h1 class="title-separate" transition:name={`tab-${activeNavItem.label.toLowerCase()}`}>
                    {activeNavItem.label}
                  </h1>
                  <nav class="page-nav-tabs">
                    {navItems.filter(item => !isNavActive(item.href, item.exact)).map(item => (
                      <a
                        href={item.href}
                        class="page-nav-link"
                        transition:name={`tab-${item.label.toLowerCase()}`}
                      >
                        {item.label}
                      </a>
                    ))}
                  </nav>
                </div>
              )}
              <slot />
            </div>
          </div>
        </div>
        <Footer />
      </div>
    </div>
  </body>
</html>

<style>
  body {
    margin: 0;
    background: var(--color-bg);
    color: var(--color-text);
    overflow-y: scroll;
  }

  .outer-padding {
    padding: 0 1.87rem 1.87rem;
  }

  @media (max-width: 768px) {
    .outer-padding {
      padding: 0.4rem;
    }
  }

  .container {
    max-width: 1264px;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  @media (min-width: 2045px) {
    .container {
      max-width: 61.8vw;
    }
  }

  /* The whole content area including sidebar */
  .main-wrapper {
    border-radius: 0 0 3rem 3rem;
    background: var(--color-bg-card);
  }

  @media (max-width: 768px) {
    .main-wrapper {
      border-radius: 1.5rem;
    }
  }

  /* Two-column flexbox grid */
  .layout-grid {
    display: flex;
    flex-wrap: wrap;
  }

  .sidebar-col {
    width: 33.33%;
    display: none;
  }

  .content-col {
    width: 66.67%;
    padding: 2.5rem;
    padding-left: 0;
  }

  @media (min-width: 768px) {
    .sidebar-col { display: block; }
  }

  @media (min-width: 992px) {
    .sidebar-col { width: 29.17%; }
    .content-col { width: 70.83%; }
  }

  @media (max-width: 767px) {
    .sidebar-col { display: none; width: 100%; }
    .content-col {
      width: 100%;
      padding: 1.5rem;
      padding-top: 0;
    }

    .main-wrapper {
      overflow: hidden;
    }
  }

  /* Page nav row: title + tabs on same line */
  .page-nav-row {
    display: flex;
    align-items: baseline;
    margin-bottom: 2.5rem;
  }

  .page-nav-row :global(.title-separate) {
    margin-bottom: 0;
  }

  .page-nav-tabs {
    display: flex;
    gap: 0.25rem;
    margin-left: auto;
  }

  .page-nav-link {
    padding: 0.4rem 0.8rem;
    border-radius: 14px;
    font-size: 14px;
    font-weight: 500;
    color: #5F6F81;
    text-decoration: none;
    transition: background 0.2s;
  }

  :global(.dark) .page-nav-link {
    color: var(--color-nav-text);
  }

  .page-nav-link:hover {
    background: var(--color-gray-100);
  }

  .sidebar-affix {
    position: sticky;
    top: 80px;
  }

  @media (max-width: 991px) {
    .sidebar-affix {
      position: static;
    }
  }

  /* Mobile profile bar */
  .mobile-profile {
    display: none;
    align-items: center;
    gap: 12px;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 767px) {
    .mobile-profile {
      display: flex;
    }
  }

  .mobile-avatar {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .mobile-profile-info {
    flex: 1;
    min-width: 0;
  }

  .mobile-profile-text {
    display: flex;
    flex-direction: column;
  }

  .mobile-social {
    margin-top: 4px;
  }

  .mobile-social :global(.social-links) {
    justify-content: flex-start;
    gap: 0;
    padding: 0;
  }

  .mobile-social :global(.social-icon-btn) {
    width: 1.75rem;
    height: 1.75rem;
    font-size: 0.9rem;
  }

  .mobile-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-heading);
    line-height: 1.3;
  }

  .mobile-role {
    font-size: 12px;
    color: var(--color-text-secondary);
  }
</style>
