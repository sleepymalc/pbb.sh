---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import SocialLinks from '../components/SocialLinks.astro';
import Footer from '../components/Footer.astro';
import type { SiteConfig } from '../types.js';
import { getNavItems, isNavActive } from '../lib/nav.js';
import { renderInlineKatex } from '../lib/katex-utils.js';

interface Props {
  config: SiteConfig;
  title?: string;
  description?: string;
  showUserInfo?: boolean;
  currentPath?: string;
}

const {
  config,
  title,
  description,
  showUserInfo = true,
  currentPath = '/',
} = Astro.props;

const pageTitle = title ? `${title} | ${config.title}` : config.title;
const pageDescription = description || config.description;

const navItems = getNavItems(config);
const activeNavItem = navItems.find(item => isNavActive(currentPath, item.href, item.exact));
const mainPaths = navItems.flatMap(n => [n.href, n.href.replace(/\/$/, '')]);
const isMainTabPage = mainPaths.includes(currentPath);

const quoteHtml = config.quote ? renderInlineKatex(config.quote) : '';

const nameParts = config.author.split(' ');
const firstName = nameParts.slice(0, -1).join(' ');
const lastName = nameParts[nameParts.length - 1];
---

<!doctype html>
<html lang={config.defaultLanguage || 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <meta name="author" content={config.author} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{pageTitle}</title>
    <ClientRouter />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Ma+Shan+Zheng&display=swap" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/academicons/1.9.4/css/academicons.min.css"
      integrity="sha512-IW0nhlW5MgNydsXJO40En2EoCkTTjZhI3yuODrZIc8cQ4h1XcF53PsqDHa09NqnkXuIe0Oiyyj171BqZFwISBw=="
      crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
      integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
      crossorigin="anonymous" />

    <script is:inline>
      (function(){
        var s=localStorage.getItem('theme'),d=window.matchMedia('(prefers-color-scheme:dark)').matches;
        if(s==='dark'||(!s&&d))document.documentElement.classList.add('dark');
        if(!window._themeSwap){
          document.addEventListener('astro:before-swap',function(e){
            e.newDocument.documentElement.classList.toggle('dark',
              document.documentElement.classList.contains('dark'));
          });
          window._themeSwap=true;
        }
      })();
    </script>
  </head>

  <body>
    <!-- Outer padding + centering (matches .outerPadding + .container) -->
    <div class="outer-padding">
      <div class="container">
        <!-- Header + content form one seamless card shape -->
        <Header config={config} currentPath={currentPath} hideTabs={isMainTabPage} />
        <div class="main-wrapper">
          <!-- Compact mobile profile bar (visible only on mobile) -->
            <div class="mobile-profile">
              <img src={`/${config.avatar}`} alt={config.author} class="mobile-avatar" />
              <div class="mobile-profile-info">
                <div class="mobile-row">
                  <div class="mobile-name-block">
                    <span class="mobile-name">{firstName}&nbsp;<span class="mobile-name-last">{lastName}</span></span>
                    {config.authorAlternative && (
                      <span class="mobile-name-alt">{config.authorAlternative}</span>
                    )}
                  </div>
                  <button class="mobile-theme-btn" id="mobile-theme-toggle" aria-label="Toggle theme">
                    <i class="fas fa-sun" id="mobile-theme-icon-sun"></i>
                    <i class="fas fa-moon" id="mobile-theme-icon-moon" style="display:none"></i>
                  </button>
                </div>
                <div class="mobile-row">
                  <div class="mobile-social">
                    <SocialLinks links={config.social} />
                  </div>
                  {quoteHtml && (
                    <span class="mobile-quote">
                      <span class="mobile-quote-mark">&ldquo;</span><span set:html={quoteHtml} /><span class="mobile-quote-mark">&rdquo;</span>
                    </span>
                  )}
                </div>
              </div>
            </div>
          <div class="layout-grid">
            <!-- Sidebar column: md=8/24, lg=7/24 -->
            <div class="sidebar-col">
              <div class="sidebar-affix">
                <Sidebar config={config} showUserInfo={showUserInfo} quoteHtml={quoteHtml}>
                  <slot name="sidebar" />
                </Sidebar>
              </div>
            </div>
            <!-- Content column: md=16/24, lg=17/24 -->
            <div class="content-col">
              {!isMainTabPage && activeNavItem && (
                <a href={activeNavItem.href} class="back-link">
                  <i class="fas fa-arrow-left"></i> {activeNavItem.label}
                </a>
              )}
              {isMainTabPage && activeNavItem && (
                <div class="page-nav-row">
                  <a href={activeNavItem.href} class="title-separate-link" transition:name={`tab-${activeNavItem.label.toLowerCase()}`}>
                    <h1 class="title-separate">
                      {activeNavItem.label}
                    </h1>
                  </a>
                  <nav class="page-nav-tabs">
                    {navItems.filter(item => !isNavActive(currentPath, item.href, item.exact)).map(item => (
                      <a
                        href={item.href}
                        class="page-nav-link"
                        transition:name={`tab-${item.label.toLowerCase()}`}
                      >
                        {item.label}
                      </a>
                    ))}
                  </nav>
                </div>
              )}
              <slot />
            </div>
          </div>
        </div>
        <Footer />
      </div>
    </div>
  </body>
</html>

<style>
  body {
    margin: 0;
    background: var(--color-bg);
    color: var(--color-text);
    overflow-y: scroll;
  }

  .outer-padding {
    padding: 3rem 1.87rem 1.87rem;
  }

  @media (max-width: 768px) {
    .outer-padding {
      padding: 0.4rem;
    }
  }

  .container {
    max-width: 1264px;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 2045px) {
    .container {
      max-width: 61.8vw;
    }
  }

  /* The whole content area including sidebar */
  .main-wrapper {
    border-radius: 0 0 3rem 3rem;
    background: var(--color-bg-card);
  }

  @media (max-width: 1023px) {
    .main-wrapper {
      border-radius: 3rem;
    }
  }

  /* Two-column flexbox grid */
  .layout-grid {
    display: flex;
    flex-wrap: wrap;
  }

  .sidebar-col {
    width: 33.33%;
    display: none;
  }

  .content-col {
    width: 66.67%;
    padding: 2.5rem;
    padding-left: 1.5rem;
  }

  @media (min-width: 1024px) {
    .sidebar-col { display: block; }
  }

  @media (min-width: 1200px) {
    .sidebar-col { width: 29.17%; }
    .content-col { width: 70.83%; }
  }

  @media (max-width: 1023px) {
    .sidebar-col { display: none; width: 100%; }
    .content-col {
      width: 100%;
      padding: 1.5rem;
      padding-top: 1.25rem;
    }

    .main-wrapper {
      overflow: clip;
    }
  }

  /* Page nav row: title + tabs on same line */
  .page-nav-row {
    display: flex;
    align-items: baseline;
    margin-bottom: 2.5rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: 0.75rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-link);
  }

  .back-link i {
    margin-right: 4px;
    font-size: 0.75rem;
  }

  .title-separate-link {
    text-decoration: none;
    color: inherit;
  }

  .page-nav-row :global(.title-separate) {
    margin-bottom: 0;
  }

  .page-nav-tabs {
    display: flex;
    gap: 0.25rem;
    margin-left: auto;
  }

  .page-nav-link {
    padding: 0.4rem 0.8rem;
    border-radius: 14px;
    font-size: 14px;
    font-weight: 500;
    color: #5F6F81;
    text-decoration: none;
    transition: background 0.2s;
  }

  :global(.dark) .page-nav-link {
    color: var(--color-nav-text);
  }

  .page-nav-link:hover {
    background: var(--color-gray-100);
  }

  .sidebar-affix {
    position: sticky;
    top: 80px;
  }

  @media (max-width: 1199px) {
    .sidebar-affix {
      position: static;
    }
  }

  /* Mobile profile bar */
  .mobile-profile {
    display: none;
    align-items: stretch;
    gap: 12px;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 1023px) {
    .mobile-profile {
      display: flex;
      position: sticky;
      top: 0;
      z-index: 50;
      background: var(--color-bg-card);
    }
  }

  .mobile-avatar {
    width: 110px;
    height: auto;
    border-radius: 22px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .mobile-profile-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .mobile-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .mobile-social :global(.social-links) {
    justify-content: flex-start;
    gap: 0;
    padding: 0;
  }

  .mobile-social :global(.social-icon-btn) {
    width: 2rem;
    height: 2rem;
    font-size: 1.05rem;
  }

  .mobile-name-block {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .mobile-name {
    font-size: 22px;
    font-weight: 200;
    letter-spacing: 1.5px;
    color: var(--color-heading);
    line-height: 1.3;
  }

  .mobile-name-last {
    font-weight: 600;
    letter-spacing: 0;
  }

  .mobile-name-alt {
    font-size: 16px;
    font-weight: 400;
    font-family: 'Ma Shan Zheng', cursive;
    color: var(--color-heading);
  }

  .mobile-theme-btn {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: none;
    background: none;
    color: var(--color-text);
    font-size: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mobile-quote {
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-size: 12px;
    color: var(--color-text-secondary);
    margin-left: auto;
  }

  .mobile-quote :global(.katex) {
    font-style: normal;
  }

  .mobile-quote-mark {
    font-size: 14px;
    color: var(--color-accent);
    opacity: 0.6;
  }
</style>
