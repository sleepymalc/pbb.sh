---
import type { SiteConfig } from '../types.js';
import { getNavItems, isNavActive } from '../lib/nav.js';

interface Props {
  config: SiteConfig;
  currentPath?: string;
  hideTabs?: boolean;
}

const { config, currentPath = '/', hideTabs = false } = Astro.props;

const navItems = getNavItems(config);
---

<!-- Sticky header -->
<header class="site-header">
  <div class="nav-wrap">
    {!hideTabs && (
      <nav class="nav-bar">
        <ul>
          {navItems.map((item) => {
            const active = isNavActive(currentPath, item.href, item.exact);
            return (
              <li class="nav-item">
                <a
                  href={item.href}
                  class:list={['nav-link', { 'nav-active': active }]}
                  transition:name={`tab-${item.label.toLowerCase()}`}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    )}
    <button id="theme-toggle" class="nav-link theme-btn" aria-label="Toggle theme">
      <i class="fas fa-sun" id="theme-icon-sun"></i>
      <i class="fas fa-moon" id="theme-icon-moon" style="display:none"></i>
    </button>
  </div>

</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    /* Body-colored strip behind the rounded nav — masks content scrolling underneath */
    background: var(--color-bg);
  }

  .nav-wrap {
    display: flex;
    align-items: center;
    background: var(--color-bg-card);
    padding-top: 8px;
    padding-bottom: 8px;
    border-radius: 3rem 3rem 0 0;
  }

  .nav-bar {
    display: flex;
    align-items: center;
    color: #5F6F81;
    font-weight: 500;
    height: 40px;
    letter-spacing: 0.04rem;
    margin-left: auto;
    position: relative;
  }

  .nav-bar ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
  }

  .nav-item {
    margin-right: 0.4rem;
  }

  .nav-link {
    display: inline-block;
    padding: 0.6rem 1rem;
    border-radius: 14px;
    font-size: 14px;
    font-weight: 500;
    color: #5F6F81;
    text-decoration: none;
    border: none;
    background: none;
    cursor: pointer;
    transition: all .2s;
  }

  :global(.dark) .nav-link {
    color: var(--color-nav-text);
  }

  .nav-link:hover {
    background: var(--color-gray-100);
  }

  .nav-active {
    background: #304CFD !important;
    color: #fff !important;
  }

  .theme-btn {
    font-size: 16px;
    padding: 0.5rem 0.7rem;
    margin-left: auto;
    margin-right: 1.5rem;
  }

  @media (max-width: 768px) {
    .nav-wrap { display: none; }
  }
</style>

<script>
  function initHeader() {
    // Theme toggles (desktop + mobile)
    const toggle = document.getElementById('theme-toggle');
    const mobileToggle = document.getElementById('mobile-theme-toggle');

    function updateIcons() {
      const isDark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('[id$="theme-icon-sun"]').forEach(el => (el as HTMLElement).style.display = isDark ? 'none' : '');
      document.querySelectorAll('[id$="theme-icon-moon"]').forEach(el => (el as HTMLElement).style.display = isDark ? '' : 'none');
    }

    function toggleTheme() {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme',
        document.documentElement.classList.contains('dark') ? 'dark' : 'light');
      updateIcons();
    }

    toggle?.addEventListener('click', toggleTheme);
    mobileToggle?.addEventListener('click', toggleTheme);
    updateIcons();
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
