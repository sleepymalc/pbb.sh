---
import type { SiteConfig } from '../types.js';

interface Props {
  config: SiteConfig;
  currentPath?: string;
}

const { config, currentPath = '/' } = Astro.props;

const navItems = [
  { label: 'About', href: '/', exact: true },
  { label: 'Experience', href: '/experience/', exact: false },
  { label: 'Research', href: `/${config.pages.research}/`, exact: false },
  { label: 'Posts', href: `/${config.pages.posts}/`, exact: false },
];

function isActive(href: string, exact: boolean): boolean {
  if (exact) return currentPath === href || currentPath === href.replace(/\/$/, '');
  return currentPath.startsWith(href) || currentPath.startsWith(href.replace(/\/$/, ''));
}
---

<!-- Sticky header -->
<header class="site-header">
  <!-- navWrap: flex row-reverse, bg card, padding 20px -->
  <div class="nav-wrap">
    <!-- nav: border-radius 0 3rem 0 0, height 60px -->
    <nav class="nav-bar">
      <ul>
        {navItems.map((item) => (
          <li class="nav-item">
            {isActive(item.href, item.exact) ? (
              <a href={item.href} class="nav-link nav-active">{item.label}</a>
            ) : (
              <a href={item.href} class="nav-link">{item.label}</a>
            )}
          </li>
        ))}
        <li class="nav-item">
          <button id="theme-toggle" class="nav-link theme-btn" aria-label="Toggle theme">
            <i class="fas fa-sun" id="theme-icon-sun"></i>
            <i class="fas fa-moon" id="theme-icon-moon" style="display:none"></i>
          </button>
        </li>
      </ul>
    </nav>
  </div>

  <!-- Mobile hamburger button -->
  <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Open menu">
    <i class="fas fa-bars"></i>
  </button>
</header>

<!-- Mobile slide-down menu -->
<div class="mobile-overlay" id="mobile-menu">
  <div class="mobile-backdrop" id="mobile-backdrop"></div>
  <nav class="mobile-drawer">
    <div class="mobile-drawer-header">
      <button id="mobile-menu-close" class="mobile-close-btn" aria-label="Close menu">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <ul>
      {navItems.map((item) => (
        <li>
          <a href={item.href} class:list={[isActive(item.href, item.exact) && 'active']}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
    <button id="mobile-theme-toggle" class="mobile-theme-btn">
      <i class="fas fa-adjust"></i> Theme
    </button>
  </nav>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    /* Body-colored strip behind the rounded nav — masks content scrolling underneath */
    background: var(--color-bg);
  }

  .nav-wrap {
    display: flex;
    flex-direction: row-reverse;
    background: var(--color-bg-card);
    padding-top: 20px;
    padding-bottom: 20px;
    border-radius: 3rem 3rem 0 0;
  }

  .nav-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #5F6F81;
    font-weight: 500;
    height: 60px;
    letter-spacing: 0.04rem;
    margin-left: auto;
    padding-right: 40px;
    position: relative;
  }

  .nav-bar ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
  }

  .nav-item {
    margin-right: 0.4rem;
  }

  .nav-link {
    display: inline-block;
    padding: 0.6rem 1rem;
    border-radius: 14px;
    font-size: 14px;
    font-weight: 500;
    color: #5F6F81;
    text-decoration: none;
    border: none;
    background: none;
    cursor: pointer;
    transition: all .2s;
  }

  :global(.dark) .nav-link {
    color: var(--color-nav-text);
  }

  .nav-link:hover {
    background: var(--color-gray-100);
  }

  .nav-active {
    background: #304CFD !important;
    color: #fff !important;
  }

  .theme-btn {
    font-size: 16px;
    padding: 0.5rem 0.7rem;
  }

  /* Hide desktop nav on mobile, show hamburger */
  .mobile-menu-btn {
    display: none;
    position: fixed;
    top: 10px;
    right: 10px;
    z-index: 1101;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    border: none;
    background: var(--color-bg-card);
    color: var(--color-text);
    font-size: 18px;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .nav-wrap { display: none; }
    .mobile-menu-btn { display: flex; }
  }

  /* Mobile overlay + drawer */
  .mobile-overlay {
    display: none;
  }

  .mobile-overlay.open {
    display: block;
  }

  .mobile-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.3);
    z-index: 1000;
  }

  .mobile-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: 260px;
    max-width: 75vw;
    height: 100%;
    z-index: 1100;
    background: var(--color-bg-card);
    padding: 1rem 1.25rem;
    box-shadow: -4px 0 16px rgba(0,0,0,0.1);
    overflow-y: auto;
  }

  .mobile-drawer-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 1rem;
  }

  .mobile-close-btn {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: none;
    background: var(--color-gray-100);
    color: var(--color-text);
    font-size: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mobile-drawer ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mobile-drawer li {
    margin-bottom: 4px;
  }

  .mobile-drawer a {
    display: block;
    padding: 10px 12px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: background 0.15s;
  }

  .mobile-drawer a:hover,
  .mobile-drawer a.active {
    background: var(--color-gray-100);
    color: var(--color-primary);
  }

  .mobile-theme-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 10px 12px;
    margin-top: 8px;
    border-radius: 10px;
    border: none;
    background: none;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text);
    cursor: pointer;
    transition: background 0.15s;
  }

  .mobile-theme-btn:hover {
    background: var(--color-gray-100);
  }
</style>

<script>
  function initHeader() {
    // Theme toggle
    const toggle = document.getElementById('theme-toggle');
    const mobileToggle = document.getElementById('mobile-theme-toggle');
    const sunIcon = document.getElementById('theme-icon-sun');
    const moonIcon = document.getElementById('theme-icon-moon');

    function updateIcons() {
      const isDark = document.documentElement.classList.contains('dark');
      if (sunIcon) sunIcon.style.display = isDark ? 'none' : '';
      if (moonIcon) moonIcon.style.display = isDark ? '' : 'none';
    }

    function toggleTheme() {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme',
        document.documentElement.classList.contains('dark') ? 'dark' : 'light');
      updateIcons();
    }

    toggle?.addEventListener('click', toggleTheme);
    mobileToggle?.addEventListener('click', toggleTheme);
    updateIcons();

    // Mobile menu
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const closeBtn = document.getElementById('mobile-menu-close');
    const backdrop = document.getElementById('mobile-backdrop');

    function openMenu() { menu?.classList.add('open'); }
    function closeMenu() { menu?.classList.remove('open'); }

    btn?.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', closeMenu);
    backdrop?.addEventListener('click', closeMenu);

    // Close on nav link click
    menu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
