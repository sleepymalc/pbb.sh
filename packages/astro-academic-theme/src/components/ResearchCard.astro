---
import Tag from './Tag.astro';
import { marked } from 'marked';

interface Author {
  name: string;
  url?: string;
}

interface Link {
  name: string;
  url: string;
}

interface Props {
  title: string;
  href: string;
  date: Date;
  excerpt: string;
  authors?: Author[];
  venue?: string;
  tags?: string[];
  tagColors?: string[];
  links?: Link[];
  cover?: string;
}

const { title, href, date, excerpt, authors = [], venue, tags = [], tagColors = [], links = [], cover } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const TRUNCATE_THRESHOLD = 7;
const SHOW_FIRST = 5;
const SHOW_LAST = 2;
const shouldTruncate = authors.length > TRUNCATE_THRESHOLD;

/** Convert inline markdown bold/italic/links to HTML */
function inlineMd(text: string): string {
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
}

/** Map link names to Font Awesome icon classes */
function linkIcon(name: string): string | null {
  const n = name.toLowerCase();
  if (n === 'github') return 'fab fa-github';
  if (n === 'arxiv') return 'ai ai-arxiv';
  if (n === 'paper' || n === 'pdf') return 'fas fa-file-pdf';
  if (n === 'poster') return 'fas fa-image';
  if (n === 'slide' || n === 'slides') return 'fas fa-desktop';
  if (n === 'talk' || n === 'video') return 'fas fa-video';
  if (n === 'website' || n === 'web' || n === 'demo') return 'fas fa-globe';
  if (n === 'code') return 'fas fa-code';
  return null;
}
---

<!-- RSuite Panel bordered, padding 0.8rem -->
<div class="research-card">
  <div class="card-grid">
    <!-- Text: md=12/24, lg=16/24 -->
    <div class="card-text">
      <h5><a href={href}>{title}</a></h5>

      {authors.length > 0 && (
        <div class="authors-row">
          {authors.map((author, i) => {
            const isHidden = shouldTruncate && i >= SHOW_FIRST && i < authors.length - SHOW_LAST;
            const isEllipsisPoint = shouldTruncate && i === SHOW_FIRST;
            return (
              <>
                {isEllipsisPoint && (
                  <span class="authors-ellipsis" role="button" tabindex="0" title="Show all authors">&hellip;,&nbsp;</span>
                )}
                <span class:list={['author', { 'author-hidden': isHidden }]}>
                  {author.url ? (
                    <a href={author.url} target="_blank" rel="noopener noreferrer" set:html={inlineMd(author.name)} />
                  ) : (
                    <span set:html={inlineMd(author.name)} />
                  )}
                  {i < authors.length - 1 ? <Fragment>,&nbsp;</Fragment> : null}
                </span>
              </>
            );
          })}
        </div>
      )}

      <!-- Info line: date | venue | tags -->
      <div class="info-line">
        {date && <div>{formattedDate}</div>}
        {venue && (
          <>
            <div class="divider"></div>
            <div><span>{venue}</span></div>
          </>
        )}
        {tags.length > 0 && (
          <>
            <div class="divider"></div>
            <div class="tags-inline">
              {tags.map((tag, i) => (
                <Tag name={tag} color={tagColors[i % tagColors.length]} />
              ))}
            </div>
          </>
        )}
      </div>

      <div class="card-details">
        <div class="card-details-inner">
          {excerpt && (
            <p class="excerpt"><Fragment set:html={marked.parseInline(excerpt)} /></p>
          )}

          {links.length > 0 && (
            <div class="links-row">
              {links.map((link) => {
                const icon = linkIcon(link.name);
                return (
                  <a
                    href={link.url}
                    target={link.url.startsWith('http') ? '_blank' : undefined}
                    rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
                    class="btn-ghost"
                  >
                    {icon && <i class={icon} style="margin-right:4px"></i>}
                    {link.name}
                  </a>
                );
              })}
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Image: md=12/24, lg=8/24 -->
    <div class="card-image-col">
      {cover ? (
        <img src={cover} alt={title} class="card-image" />
      ) : (
        <div class="card-image-placeholder"></div>
      )}
    </div>
  </div>
</div>

<style>
  .research-card {
    padding: 0.8rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-base);
    background: var(--color-bg-card);
    cursor: pointer;
  }

  .card-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .card-text {
    flex: 1;
    min-width: 0;
  }

  .card-image-col {
    width: 25%;
    flex-shrink: 0;
    position: relative;
    padding-top: 9%;
    overflow: hidden;
    background: transparent;
    border-radius: var(--radius-base);
  }

  @media (max-width: 767px) {
    .card-image-col {
      width: 25%;
      padding-top: 14%;
      margin: 0 auto;
    }
  }

  .card-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: var(--radius-base);
  }

  .card-image-placeholder {
    /* Handled by parent padding-top */
  }

  .research-card h5 {
    font-size: 1.2rem;
    white-space: normal;
    line-height: 1.25;
    margin-bottom: 0.15rem;
  }

  .research-card h5 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .research-card h5 a:hover {
    color: var(--color-heading);
  }

  .authors-row {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin-bottom: 0.15rem;
    line-height: 1.4;
  }

  .authors-row a {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .authors-row a:hover {
    color: var(--color-text);
  }

  .author-hidden {
    display: none;
  }

  .authors-row.expanded .author-hidden {
    display: inline;
  }

  .authors-row.expanded .authors-ellipsis {
    display: none;
  }

  .authors-ellipsis {
    cursor: pointer;
    color: var(--color-text-secondary);
  }

  .authors-ellipsis:hover {
    color: var(--color-text);
  }

  .info-line {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    margin-top: 0.25rem;
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  .divider {
    border-left: 1.5px solid rgba(0, 0, 0, 0.2);
    height: 1.2em;
    margin-left: 6px;
    margin-right: 6px;
    align-self: center;
  }

  :global(.dark) .divider {
    border-left-color: rgba(255, 255, 255, 0.2);
  }

  .tags-inline {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .card-details {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.25s ease;
  }

  .card-details-inner {
    overflow: hidden;
  }

  .card-details.expanded {
    grid-template-rows: 1fr;
  }

  .excerpt {
    margin-top: 0.75rem;
    margin-bottom: 0;
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .links-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 0.75rem;
    padding-bottom: 0.25rem;
  }

  @media (max-width: 480px) {
    .research-card {
      padding: 0.6rem;
    }

    .research-card h5 {
      font-size: 1.05rem;
    }

    .authors-row {
      font-size: 12px;
    }

    .info-line {
      font-size: 12px;
    }

    .excerpt {
      font-size: 12px;
      margin-top: 0.75rem;
    }

    .links-row {
      margin-top: 0.75rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.authors-ellipsis').forEach((el) => {
    el.addEventListener('click', () => {
      el.closest('.authors-row')?.classList.add('expanded');
    });
  });

  document.querySelectorAll('.research-card').forEach((card) => {
    card.addEventListener('click', (e) => {
      // Let actual links (title, author links, arxiv/github buttons) navigate normally
      const target = e.target as HTMLElement;
      if (target.closest('a')) return;

      card.querySelector('.card-details')?.classList.toggle('expanded');
    });
  });
</script>
