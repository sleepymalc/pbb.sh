---
const now = new Date();
const formatted = now.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<footer>
  <p class="text-center text-sm text-[var(--color-text-tertiary)] py-4">
    Last Updated on {formatted}
  </p>
</footer>

<style>
  footer {
    padding-bottom: 1rem;
  }
</style>
