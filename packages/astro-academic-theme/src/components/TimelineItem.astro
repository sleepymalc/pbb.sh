---
interface Props {
  title: string;
  subtitle?: string;
  minor?: string;
  date?: string;
  icon?: string;
  iconColor?: string;
  logo?: string;
  logoDark?: string;
  entityColor?: string;
  entityColorDark?: string;
}

const { title, subtitle, minor, date, icon = 'school', iconColor = '#44566C', logo, logoDark, entityColor, entityColorDark } = Astro.props;

---

<div class="timeline-item">
  <div class:list={['timeline-icon', { 'timeline-icon-logo': !!logo }]}>
    {logo && logoDark ? (
      <>
        <img src={logo} alt="" class="timeline-logo timeline-logo-light" />
        <img src={logoDark} alt="" class="timeline-logo timeline-logo-dark" />
      </>
    ) : logo ? (
      <img src={logo} alt="" class="timeline-logo" />
    ) : (
      <i class={`fas fa-${icon}`} style={`color: ${iconColor}`}></i>
    )}
  </div>
  <div class="timeline-body">
    <p class="timeline-title">{title}{minor && <span class="timeline-minor"> · Minor in {minor}</span>}</p>
    {subtitle && (
      entityColor
        ? <p class="entity-mention entity-mention-sm" style={`--entity-color: ${entityColor}; --entity-color-dark: ${entityColorDark || entityColor}`}>{subtitle}</p>
        : <p class="timeline-subtitle">{subtitle}</p>
    )}
    {date && (
      <p class="timeline-date">{date}</p>
    )}
    <slot />
  </div>
</div>

<style>
  .timeline-item {
    display: flex;
    gap: 1rem;
    padding: 0.6rem 0;
    position: relative;
  }

  .timeline-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    background: var(--color-bg-card);
    box-shadow: 0 0 0 4px var(--color-bg-card);
    font-size: 13px;
  }

  .timeline-icon-logo {
    width: 28px;
    height: 28px;
    margin-left: -4px;
    background: var(--color-bg-card);
    border-radius: 4px;
  }

  .timeline-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 4px;
  }

  .timeline-logo-dark {
    display: none;
  }

  :global(.dark) .timeline-logo-light {
    display: none;
  }

  :global(.dark) .timeline-logo-dark {
    display: block;
  }

  :global(.dark) .timeline-logo-dark[src$="nii.png"] {
    filter: brightness(1.6);
  }

  .timeline-body {
    flex: 1;
    min-width: 0;
    margin-top: -2px;
  }

  .timeline-title {
    font-size: 11pt;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.35;
    margin: 0;
  }

  .timeline-minor {
    font-size: 10pt;
    font-weight: 400;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .timeline-subtitle {
    font-size: 12pt;
    font-weight: 400;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .timeline-date {
    font-size: 13px;
    color: var(--color-text-tertiary);
    margin: 0;
  }
</style>
