---
interface Props {
  title: string;
  subtitle?: string;
  minor?: string;
  date?: string;
  icon?: string;
  iconColor?: string;
  logo?: string;
  logoDark?: string;
  entityColor?: string;
}

const { title, subtitle, minor, date, icon = 'school', iconColor = '#44566C', logo, logoDark, entityColor } = Astro.props;

---

<div class="timeline-item">
  <div class:list={['timeline-icon', { 'timeline-icon-logo': !!logo }]}>
    {logo && logoDark ? (
      <>
        <img src={logo} alt="" class="timeline-logo timeline-logo-light" />
        <img src={logoDark} alt="" class="timeline-logo timeline-logo-dark" />
      </>
    ) : logo ? (
      <img src={logo} alt="" class="timeline-logo" />
    ) : (
      <i class={`fas fa-${icon}`} style={`color: ${iconColor}`}></i>
    )}
  </div>
  <div class="timeline-body">
    <p class="timeline-title">{title}</p>
    {minor && (
      <p class="timeline-minor"><i class="fas fa-bookmark"></i> Minor in {minor}</p>
    )}
    {subtitle && (
      entityColor
        ? <p class="timeline-subtitle timeline-subtitle-entity" style={`--entity-color: ${entityColor}`}>{subtitle}</p>
        : <p class="timeline-subtitle">{subtitle}</p>
    )}
    {date && (
      <p class="timeline-date">{date}</p>
    )}
    <slot />
  </div>
</div>

<style>
  .timeline-item {
    display: flex;
    gap: 1rem;
    padding: 0.6rem 0;
    position: relative;
  }

  .timeline-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    background: var(--color-bg-card);
    font-size: 13px;
  }

  .timeline-icon-logo {
    width: 28px;
    height: 28px;
    margin-left: -4px;
    background: var(--color-bg-card);
    border-radius: 4px;
  }

  .timeline-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 4px;
  }

  .timeline-logo-dark {
    display: none;
  }

  :global(.dark) .timeline-logo-light {
    display: none;
  }

  :global(.dark) .timeline-logo-dark {
    display: block;
  }

  .timeline-body {
    flex: 1;
    min-width: 0;
    margin-top: -2px;
  }

  .timeline-title {
    font-size: 11pt;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.35;
    margin: 0;
  }

  .timeline-minor {
    font-size: 10pt;
    font-weight: 500;
    color: var(--color-text-secondary);
    margin: 2px 0 0;
    font-style: italic;
  }

  .timeline-minor i {
    font-size: 9px;
    margin-right: 4px;
    opacity: 0.6;
  }

  .timeline-subtitle {
    font-size: 12pt;
    font-weight: 400;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .timeline-subtitle-entity {
    font-weight: 600;
    color: var(--entity-color);
    background: color-mix(in srgb, var(--entity-color) 10%, transparent);
    border-bottom: 2px solid color-mix(in srgb, var(--entity-color) 40%, transparent);
    padding: 1px 6px;
    border-radius: 4px;
    width: fit-content;
  }

  :global(.dark) .timeline-subtitle-entity {
    color: color-mix(in srgb, var(--entity-color) 55%, #fff);
    background: color-mix(in srgb, var(--entity-color) 8%, transparent);
    border-bottom-color: color-mix(in srgb, var(--entity-color) 30%, transparent);
  }

  .timeline-date {
    font-size: 13px;
    color: var(--color-text-tertiary);
    margin: 0;
  }
</style>
