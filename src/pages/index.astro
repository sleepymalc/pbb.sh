---
import BaseLayout from '@/layouts/Layout.astro';
import ResearchCard from 'astro-academic-theme/components/ResearchCard.astro';
import { siteConfig } from '@/config';
import { renderMarkdown } from '@/lib/markdown';
import { highlightEntities } from '@/lib/entities';
import { getCollection } from 'astro:content';

// Get selected research
const allResearch = await getCollection('research');
const selectedResearch = allResearch
  .filter((r) => r.data.selected)
  .sort((a, b) => {
    const pa = a.data.priority ?? 0;
    const pb = b.data.priority ?? 0;
    if (pa !== pb) return pa - pb;
    return a.data.title.localeCompare(b.data.title);
  });

// Build a stable tag→color map using ALL research tags (same order as research page)
const allResearchTags = [...new Set(allResearch.flatMap((r) => r.data.tags))];
const tagColorMap = new Map<string, string>();
allResearchTags.forEach((tag, i) => {
  tagColorMap.set(tag, siteConfig.tagColors[i % siteConfig.tagColors.length]);
});
function colorsFor(tags: string[]): string[] {
  return tags.map((t) => tagColorMap.get(t) || siteConfig.tagColors[0]);
}

// Render introduction markdown
const introHtml = highlightEntities(
  siteConfig.introduction
    .map((para) => renderMarkdown(para))
    .join('\n')
);

// Render research intro markdown
const researchIntroHtml = highlightEntities(
  (siteConfig.researchIntro ?? [])
    .map((p) => renderMarkdown(p))
    .join('\n')
);

// Render news items
const newsItems = (siteConfig.news ?? []).map((item) => ({
  date: item.date,
  html: highlightEntities(renderMarkdown(item.text)),
}));

// Render misc
const miscHtml = siteConfig.misc ? renderMarkdown(siteConfig.misc) : '';
---

<BaseLayout config={siteConfig} currentPath="/">
  <!-- About Me -->
  <section>
    <div class="markdown-body intro-content" set:html={introHtml} />
  </section>

  <!-- Research -->
  {researchIntroHtml && (
    <section class="mt-6">
      <h3 class="section-heading">🔬 Research</h3>
      <div class="markdown-body research-content" set:html={researchIntroHtml} />
    </section>
  )}

  <!-- News -->
  {newsItems.length > 0 && (
    <section class="mt-6">
      <h3 class="section-heading">🗞️ News</h3>
      <ul class="news-list">
        {newsItems.map((item) => (
          <li>
            <span class="news-date">{item.date}</span>
            <span class="news-text" set:html={item.html} />
          </li>
        ))}
      </ul>
    </section>
  )}

  <style>
    .section-heading {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--color-heading);
      margin-bottom: 0.6rem;
      padding-bottom: 0.3rem;
      border-bottom: 2px solid var(--color-accent);
      display: inline-block;
    }

    /* Italic keywords in research prose: subtle accent underline */
    .research-content :global(p em) {
      font-style: italic;
      text-decoration: underline;
      text-decoration-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
      text-underline-offset: 2px;
      text-decoration-thickness: 1.5px;
    }

    /* Bold text in research prose (e.g., "data"): accent colored */
    .research-content :global(p strong) {
      color: var(--color-accent);
    }

    /* Direction titles in the numbered list */
    .research-content :global(ol strong) {
      color: var(--color-accent);
      cursor: default;
      transition: text-shadow 0.3s ease;
    }

    .research-content :global(ol strong:hover) {
      animation: keyword-glow 1.5s ease-in-out infinite;
    }

    @keyframes keyword-glow {
      0%, 100% { text-shadow: 0 0 4px color-mix(in srgb, var(--color-accent) 40%, transparent); }
      50% { text-shadow: 0 0 12px color-mix(in srgb, var(--color-accent) 70%, transparent); }
    }

    .news-list {
      max-height: 180px;
      overflow-y: auto;
      padding-right: 0.5rem;
      padding-left: 0;
      list-style: none;
    }

    .news-list li {
      display: flex;
      gap: 0.5em;
      padding: 0.15em 0;
      font-size: 16px;
      line-height: 1.6;
    }

    .news-date {
      flex-shrink: 0;
      width: 5.5em;
      font-size: 1em;
      font-weight: 500;
      white-space: nowrap;
      color: var(--color-text-secondary);
      border-right: 2px solid var(--color-accent);
      padding-right: 0.5em;
      text-align: right;
      height: fit-content;
      margin-top: 1px;
    }

    .news-text {
      flex: 1;
      min-width: 0;
    }

    /* Strip wrapping <p> tags from inline markdown in news items */
    .news-text :global(p) {
      margin: 0;
      display: inline;
    }

    .research-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      max-height: 300px;
      overflow-y: auto;
      padding-right: 0.5rem;
      scroll-snap-type: y mandatory;
    }

    .research-list > :global(*) {
      scroll-snap-align: start;
    }

    @media (max-width: 640px) {
      .research-list {
        flex-direction: row;
        max-height: none;
        overflow-y: visible;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        padding-right: 0;
        padding-bottom: 0.5rem;
      }

      .research-list > :global(*) {
        flex: 0 0 85%;
      }
    }
  </style>

  <!-- Selected Research -->
  {selectedResearch.length > 0 && (
    <section class="mt-8">
      <h3 class="section-heading">📄 Selected Research</h3>
      <div class="research-list">
        {selectedResearch.map((paper) => (
          <ResearchCard
            title={paper.data.title}
            href={`/${paper.data.path}/`}
            date={paper.data.date}
            excerpt={paper.data.excerpt}
            authors={paper.data.authors}
            venue={paper.data.venue}
            tags={paper.data.tags}
            tagColors={colorsFor(paper.data.tags)}
            links={paper.data.links}
            cover={paper.data.cover}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Misc -->
  {miscHtml && (
    <section class="mt-6">
      <h3 class="section-heading">🔖 Misc</h3>
      <div class="markdown-body" set:html={miscHtml} />
    </section>
  )}
</BaseLayout>
